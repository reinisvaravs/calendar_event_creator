# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-from-BotFather
TELEGRAM_ALLOWED_USER_ID=123456789          # your numeric Telegram user id
TELEGRAM_WEBHOOK_SECRET=some-long-random-string

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Google Calendar ---
# The service account JSON, either raw or base64-encoded (base64 is easier on Render).
# Reuse the same service account you use for Sheets — just enable the Calendar API
# on its project and share your calendar with the service account's client_email.
GOOGLE_SERVICE_ACCOUNT_JSON=
# The calendar to write to — usually your Gmail address.
GOOGLE_CALENDAR_ID=you@gmail.com

# --- General ---
DEFAULT_TIMEZONE=Europe/Riga
PORT=3000
